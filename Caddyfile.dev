# Caddyfile for development
# Local development with auto-reload and debug logging

{
	admin 0.0.0.0:2019
	log default {
		level debug
		format json
	}
	http_port 80
	https_port 443
}

# Main dashboard
localhost:80 {
	encode gzip

	# API routes
	handle /api/* {
		reverse_proxy host.docker.internal:8080 {
			header_up -User-Agent
		}
	}

	handle /webhook/* {
		reverse_proxy host.docker.internal:8080 {
			header_up -User-Agent
		}
	}

	# Reverse proxy to SvelteKit frontend running on the host
	handle {
		reverse_proxy host.docker.internal:5173
	}

	log {
		level debug
	}
}
