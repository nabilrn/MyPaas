# Environment: development | staging | production
ENVIRONMENT=development

# PostgreSQL
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mypaas_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=mypaas_dev

# Server
API_HOST=127.0.0.1
API_PORT=8080
FRONTEND_URL=http://localhost:5173

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_CALLBACK_URL=http://localhost:8080/auth/github/callback
OWNER_EMAIL=your_github_primary_email@example.com

# JWT
JWT_SECRET=your_256bit_base64_encoded_secret_here_min_32_bytes

# Encryption (AES-256-GCM for env vars)
ENCRYPTION_KEY=your_base64_encoded_32byte_key_here

# Docker
DOCKER_SOCKET=/var/run/docker.sock
# Linux/prod container can use unix:///var/run/docker.sock.
# On Windows local dev, leave DOCKER_HOST empty so Docker Desktop's context/npipe is used.
DOCKER_HOST=
# Dockerized Caddy reaches project ports through host.docker.internal, so local dev needs 0.0.0.0.
# Use 127.0.0.1 when Caddy runs directly on the host.
DOCKER_BIND_HOST=0.0.0.0

# Cloudflare Tunnel (production only)
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here
CLOUDFLARE_ACCOUNT_ID=your_account_id_here
CLOUDFLARE_ZONE_ID=your_zone_id_here
PUBLIC_DOMAIN=nabilrizkinavisa.me

# Resource quotas
USER_RAM_QUOTA_GB=6
USER_CPU_QUOTA=3
MAX_PROJECTS=20
PROJECT_DEFAULT_RAM_MB=512
PROJECT_DEFAULT_CPU=0.5

# Features
ENABLE_WEBHOOKS=true
ENABLE_METRICS=true
METRICS_USERNAME=mypaas
METRICS_PASSWORD=change_this_metrics_password
MAX_CONCURRENT_DEPLOYS=2
BUILD_TIMEOUT_MINUTES=30

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Caddy reverse proxy
CADDY_ADMIN=127.0.0.1:2019
# Caddy runs in Docker by default, while deployed containers publish ports on the host.
# Use 127.0.0.1 only when Caddy itself runs directly on the host.
CADDY_UPSTREAM_HOST=host.docker.internal
CADDY_METRICS=true
